      "backup": "timed"
    },
    "guidance": {
      "type": "onboard_ir_fire_and_forget",
      "maneuver_class": "low_maneuver",
      "control_surfaces": "small_movable_canards_near_nose",
      "high_off_boresight": false,
      "lock_before_launch": true,
      "lock_indication": "audible_tone"
    },
    "fins": {
      "count": 4,
      "type": "swept_spring_loaded",
      "location": "base",
      "deploy": "on_exit"
    },
    "motor": {
      "type": "progressive_burn",
      "initial_phase_s": { "min": 1, "max": 2 },
      "initial_thrust_n_avg": 700,
      "peak_thrust_n": 1050,
      "ramp": "increasing_to_terminal_velocity"
    },
    "round_packaging": {
      "type": "ravioli_can_protective_tube",
      "cap": "pull_off",
      "removed_by": "soldier_during_loading"
    },
    "breech": {
      "style": "gustav_flip",
      "bolt": "spring_loaded",
      "lock_type": "positive_deadbolt",
      "unlock_action": "pull_bolt_handle_rearward_15_to_25_mm_against_spring",
      "unlock_cam": "lifts_deadbolt_detent_off_block",
      "open_angle_deg": 90,
      "lock_feedback": "deadbolt_snap_audible_tactile",
      "seating_sensors": [
        "pressure_transducer_port",
        "rim_electrical_contacts"
      ],
      "components": [
        "flip_breech_block",
        "hinge_axis",
        "spring_return_bolt_handle",
        "unlock_cam",
        "deadbolt_detent_cam",
        "bore_sealing_face",
        "rim_electrical_contacts",
        "pressure_transducer_port",
        "recoilless_vent_path"
      ],
      "states": [
        "OPEN_EMPTY",
        "OPEN_LOADED",
        "CLOSING",
        "LOCKED_SEATED",
        "SEEKER_ARMED",
        "SEEKER_LOCKED",
        "FIRED"
      ]
    },
    "rocket_retention_stop": {
      "type": "mechanical_bore_stop",
      "mechanism": "spring_biased_radial_bore_finger_on_tube_aft_shoulder",
      "default_state": "engaged",
      "retract_driver": "release_cam_from_fire_control_interlock",
      "rear_trigger_retracts_stop": false,
      "disengage_requires": [
        "breech_fully_closed_and_locked",
        "front_trigger_held",
        "seeker_ready_tone"
      ],
      "reengage_on": "front_trigger_released",
      "purpose": "prevent_rocket_forward_slide_when_slung_or_carried"
    },
    "operational_sequence_soldier": [
      {
        "phase": 1,
        "name": "CLEAR",
        "action": "Pull bolt handle; swing breech open; clear bore",
        "feedback": "Spring resistance; hinge swing; open detent",
        "interlock": "Rear disabled; seeker off; retention engaged"
      },
      {
        "phase": 2,
        "name": "PREP",
        "action": "Remove pull-off cap; inspect seeker dome",
        "feedback": "Cap separates cleanly",
        "interlock": null
      },
      {
        "phase": 3,
        "name": "LOAD",
        "action": "Slide protective tube into bore until seated",
        "feedback": "Light alignment detent",
        "interlock": "Seeker off; retention engaged"
      },
      {
        "phase": 4,
        "name": "SEAT",
        "action": "Close breech; release bolt handle for deadbolt snap",
        "feedback": "Audible deadbolt snap; seat confirm",
        "interlock": "Rear blocked until lock tone"
      },
      {
        "phase": 5,
        "name": "ARM",
        "action": "Hold front trigger; rough aim",
        "feedback": "Seeker search; stop engaged until tone",
        "interlock": "Rear blocked"
      },
      {
        "phase": 6,
        "name": "FIRE",
        "action": "Maintain tone; pull rear while holding front",
        "feedback": "Steady tone; stop disengages; launch and rear vent",
        "interlock": "Front must stay held"
      },
      {
        "phase": 7,
        "name": "POST",
        "action": "Clear 10 yd rear; open breech; tube drops",
        "feedback": "Tube falls free",
        "interlock": "Retention engaged; ready for reload"
      }
    ],
    "launcher_ergonomics": {
      "heritage": "modernized_m1_bazooka",
      "shoulder_stock": false,
      "forward_grip": "vertical_foregrip_aft_of_muzzle_before_sight",
      "rear_grip": "pistol_grip_with_fire_trigger",
      "padding": "rear_only_pistol_grip_to_breech",
      "sight": "holographic_on_short_rail",
      "finish": "matte_tactical_camo",
      "concept_art": "visuals/launcher/output/radr-bazooka-side-v5.png"
    },
    "launcher_controls": {
      "front_trigger": "seeker_activation_and_lock_tone",
      "rear_trigger": "launch_requires_front_held"
    },
    "center_of_gravity": "slightly_rear_biased",
    "backblast": {
      "yards_max": 10,
      "feet_max": 30,
      "status": "locked"
    },
    "operational_flow": [
      {
        "phase": "CLEAR",
        "action": "open_breech_eject_spent_tube",
        "system_state": "BREECH_OPEN",
        "interlock": "rear_trigger_disabled"
      },
      {
        "phase": "PREP",
        "action": "pull_off_cap_inspect_round",
        "system_state": "ROUND_EXPOSED",
        "interlock": null
      },
      {
        "phase": "LOAD",
        "action": "insert_tube_close_breech",
        "system_state": "BREECH_CLOSING",
        "interlock": null
      },
      {
        "phase": "SEAT",
        "action": "deadbolt_lock_pressure_contacts_confirm",
        "system_state": "LOCKED_SEATED",
        "interlock": "seeker_off_until_seated"
      },
      {
        "phase": "ARM",
        "action": "hold_front_trigger_wait_lock_tone",
        "system_state": "SEEKER_ARMED",
        "interlock": "rear_blocked_until_tone_retention_engaged"
      },
      {
        "phase": "READY",
        "action": "lock_tone_retention_stop_disengages",
        "system_state": "SEEKER_LOCKED",
        "interlock": "rear_enabled_retention_disengaged"
      },
      {
        "phase": "FIRE",
        "action": "pull_rear_while_holding_front",
        "system_state": "LAUNCH",
        "interlock": "front_must_stay_held"
      },
      {
        "phase": "POST",
        "action": "open_breech_empty_tube_drops",
        "system_state": "BREECH_OPEN_EMPTY",
        "interlock": "clear_10yd_rear"
      }
    ],
    "philosophy": {
